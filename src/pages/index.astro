---
import Layout from '../layouts/Layout.astro';

const videos = [
  {
    id: 'O_ZaokZ9U8Q',
    title: 'Analú - Rumba',
  },
  {
    id: '3CB104KZw2g',
    title: 'Analú - NO COJA LUCHA (Official Video)',
  },
  {
    id: 'a_vhHPpTbDk',
    title: 'Analú - De Cero',
  },
  {
    id: 'R4-rLZqEo1A',
    title: 'Analú - Hija De La Perla (Video Oficial)',
  },
  {
    id: 'qqK4phpPwZ8',
    title: 'Analú Showcase BOmm 2025 ⚡️',
  },
  {
    id: '3QKkEqCUh6o',
    title: 'Analú - QUEEN (Live Session)',
  },
];

const latestSingle = {
  title: 'PA LOS MANES',
  id: 'dSacm-lk3ew',
  listenUrl: 'https://www.youtube.com/watch?v=dSacm-lk3ew',
};
---

<Layout>
  <!-- NAV -->
  <header class="fixed top-0 left-0 w-full z-50 bg-gradient-to-b from-black/80 to-transparent">
    <nav class="max-w-7xl mx-auto px-10 py-6 flex items-center justify-between">
      <a href="#hero" class="block">
        <img src="/analulogo.png" alt="Analú" class="h-16 w-auto"  />
      </a>
      <ul class="hidden md:flex gap-10 text-base font-semibold tracking-widest uppercase text-white">
        <li><a href="#musica" class="hover:text-[#c8a96e] transition-colors">Música</a></li>
        <li><a href="#videos" class="hover:text-[#c8a96e] transition-colors">Videos</a></li>
        <li><a href="#newsletter" class="hover:text-[#c8a96e] transition-colors">Newsletter</a></li>
        <li><a href="#contacto" class="hover:text-[#c8a96e] transition-colors">Contacto</a></li>
      </ul>
    </nav>
  </header>

  <!-- HERO -->
  <section id="hero" class="relative min-h-screen flex flex-col overflow-hidden bg-black">
    <!-- subtle bottom gradient so logo stays readable -->
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-transparent to-black/60 z-10"></div>

    <img
      src="/hero.jpg"
      alt="Analú"
      class="absolute inset-0 w-full h-full object-cover object-top opacity-90"
    />

    <!-- bottom content: logo + social icons -->
    <div class="relative z-20 mt-auto pb-4 px-8 flex flex-col items-center gap-5">
      <img
        src="/analulogo.png"
        alt="Analú"
        class="w-[clamp(8rem,18vw,14rem)]"
        style="filter: brightness(0) invert(1);"
      />
      <!-- social icons row -->
      <div class="flex items-center gap-7">
        <!-- Instagram -->
        <a href="https://www.instagram.com/analumusic/" target="_blank" rel="noopener"
          class="text-white/70 hover:text-[#c8a96e] transition-colors" aria-label="Instagram">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 1.366.062 2.633.326 3.608 1.301.975.975 1.24 2.242 1.301 3.608.058 1.266.069 1.646.069 4.85s-.011 3.584-.069 4.85c-.061 1.366-.326 2.633-1.301 3.608-.975.975-2.242 1.24-3.608 1.301-1.266.058-1.646.069-4.85.069s-3.584-.011-4.85-.069c-1.366-.061-2.633-.326-3.608-1.301-.975-.975-1.24-2.242-1.301-3.608C2.175 15.584 2.163 15.204 2.163 12s.012-3.584.07-4.85c.062-1.366.326-2.633 1.301-3.608C4.509 2.489 5.776 2.225 7.142 2.163 8.408 2.105 8.788 2.163 12 2.163zm0-2.163c-3.259 0-3.667.014-4.947.072-1.477.068-2.908.41-3.993 1.494C1.975 2.65 1.633 4.081 1.565 5.558 1.507 6.838 1.493 7.246 1.493 12s.014 5.162.072 6.442c.068 1.477.41 2.908 1.494 3.993 1.085 1.085 2.516 1.426 3.993 1.494C8.333 23.986 8.741 24 12 24s3.667-.014 4.947-.072c1.477-.068 2.908-.41 3.993-1.494 1.085-1.085 1.426-2.516 1.494-3.993.058-1.28.072-1.688.072-6.442s-.014-5.162-.072-6.442c-.068-1.477-.41-2.908-1.494-3.993C21.855 1.04 20.424.698 18.947.63 17.667.572 17.259.558 14 .558zm0 5.838a5.604 5.604 0 100 11.208 5.604 5.604 0 000-11.208zm0 9.245a3.641 3.641 0 110-7.282 3.641 3.641 0 010 7.282zm5.807-9.47a1.309 1.309 0 100-2.618 1.309 1.309 0 000 2.618z"/>
          </svg>
        </a>
        <!-- YouTube -->
        <a href="https://www.youtube.com/@AnaluMusic" target="_blank" rel="noopener"
          class="text-white/70 hover:text-[#c8a96e] transition-colors" aria-label="YouTube">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
            <path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
          </svg>
        </a>
        <!-- Spotify -->
        <a href="https://open.spotify.com/intl-es/artist/7wq81ecx1CuljMAKmQ0qbV" target="_blank" rel="noopener"
          class="text-white/70 hover:text-[#c8a96e] transition-colors" aria-label="Spotify">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.441 17.314a.75.75 0 01-1.032.249c-2.823-1.724-6.376-2.114-10.565-1.158a.75.75 0 01-.334-1.463c4.583-1.047 8.516-.596 11.682 1.34a.75.75 0 01.249 1.032zm1.452-3.23a.937.937 0 01-1.288.308c-3.231-1.986-8.155-2.562-11.977-1.403a.937.937 0 01-.546-1.793c4.366-1.328 9.79-.685 13.503 1.6a.937.937 0 01.308 1.288zm.124-3.361c-3.876-2.302-10.276-2.514-13.974-1.39a1.125 1.125 0 01-.653-2.151c4.247-1.289 11.306-1.04 15.768 1.608a1.125 1.125 0 01-1.141 1.933z"/>
          </svg>
        </a>
        <!-- Apple Music -->
        <a href="https://music.apple.com/us/artist/anal%C3%BA/1458384047" target="_blank" rel="noopener"
          class="text-white/70 hover:text-[#c8a96e] transition-colors" aria-label="Apple Music">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
            <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- LATEST RELEASE -->
  <section id="musica" class="py-24 px-6 bg-[#0a0a0a]">
    <div class="max-w-5xl mx-auto">
      <p class="text-[#c8a96e] tracking-[0.4em] text-xs uppercase mb-2">Último lanzamiento</p>
      <h2 class="text-6xl md:text-8xl text-white mb-12" style="font-family:'Bebas Neue',sans-serif">
        {latestSingle.title}
      </h2>
      <div class="flex flex-col md:flex-row gap-8 items-center">
        <!-- Photo instead of thumbnail -->
        <div class="relative overflow-hidden flex-shrink-0 w-full md:w-80 aspect-[3/4]">
          <img
            src="/Analu14.jpg"
            alt="Analú - Pa Los Manes"
            class="w-full h-full object-cover object-top"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
        </div>
        <div class="flex flex-col gap-6">
          <p class="text-white/60 text-lg leading-relaxed">
            El nuevo sencillo de Analú ya disponible en todas las plataformas.
          </p>
          <a href={latestSingle.listenUrl} target="_blank" rel="noopener"
            class="inline-block w-fit px-10 py-4 bg-[#c8a96e] text-black text-sm font-semibold tracking-widest uppercase hover:bg-white transition-colors">
            ESCUCHAR AHORA
          </a>
          <div class="flex gap-5 mt-2">
            <a href="https://open.spotify.com/intl-es/artist/7wq81ecx1CuljMAKmQ0qbV" target="_blank" rel="noopener"
              class="text-white/40 hover:text-white transition-colors text-xs tracking-widest uppercase">Spotify</a>
            <a href="https://music.apple.com/us/artist/anal%C3%BA/1458384047" target="_blank" rel="noopener"
              class="text-white/40 hover:text-white transition-colors text-xs tracking-widest uppercase">Apple Music</a>
            <a href="https://www.youtube.com/@AnaluMusic" target="_blank" rel="noopener"
              class="text-white/40 hover:text-white transition-colors text-xs tracking-widest uppercase">YouTube</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- QUEEN DIVIDER — Analu7 boat/ocean/crown shot -->
  <section class="relative h-[70vh] overflow-hidden">
    <img
      src="/Analu8.jpg"
      alt="Analú - Queen of the Island"
      class="absolute inset-0 w-full h-full object-cover object-center"
    />
    <div class="absolute inset-0 bg-black/40"></div>
    <div class="absolute inset-0 flex flex-col items-center justify-center text-center px-4">
      <p class="text-[#c8a96e] tracking-[0.5em] text-xs uppercase mb-3">Analú</p>
      <h2 class="text-[clamp(3rem,10vw,8rem)] leading-none text-white" style="font-family:'Bebas Neue',sans-serif">
        QUEEN OF THE ISLAND
      </h2>
      <p class="text-white/60 tracking-[0.3em] text-sm uppercase mt-4">Pacific to the World</p>
    </div>
  </section>

  <!-- GALLERY -->
  <section class="bg-[#0a0a0a] py-2">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-1">
      <div class="overflow-hidden aspect-square">
        <img src="/Analu1.jpg" alt="Analú" class="w-full h-full object-cover hover:scale-105 transition-transform duration-700" />
      </div>
      <div class="overflow-hidden aspect-square">
        <img src="/Analu3.jpg" alt="Analú" class="w-full h-full object-cover object-top hover:scale-105 transition-transform duration-700" />
      </div>
      <div class="overflow-hidden aspect-square">
        <img src="/Analu6.jpg" alt="Analú" class="w-full h-full object-cover hover:scale-105 transition-transform duration-700" />
      </div>
      <div class="overflow-hidden aspect-square">
        <img src="/Analu13.jpg" alt="Analú" class="w-full h-full object-cover hover:scale-105 transition-transform duration-700" />
      </div>
    </div>
  </section>

  <!-- VIDEOS -->
  <section id="videos" class="py-24 px-6 bg-[#111111]">
    <div class="max-w-6xl mx-auto">
      <p class="text-[#c8a96e] tracking-[0.4em] text-xs uppercase mb-2">Contenido</p>
      <h2 class="text-6xl md:text-8xl text-white mb-12" style="font-family:'Bebas Neue',sans-serif">VIDEOS</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-5">
        {videos.map((v) => (
          <a
            href={`https://www.youtube.com/watch?v=${v.id}`}
            target="_blank"
            rel="noopener"
            class="group relative overflow-hidden block"
          >
            <img
              src={`https://i.ytimg.com/vi/${v.id}/maxresdefault.jpg`}
              alt={v.title}
              class="w-full aspect-video object-cover group-hover:scale-105 transition-transform duration-500"
            />
            <div class="absolute inset-0 bg-black/40 group-hover:bg-black/20 transition-colors"></div>
            <div class="absolute bottom-0 left-0 right-0 p-4 bg-gradient-to-t from-black/80 to-transparent">
              <p class="text-white text-sm font-semibold uppercase tracking-wide">{v.title}</p>
            </div>
            <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">
              <svg class="w-14 h-14 text-white" fill="currentColor" viewBox="0 0 24 24">
                <path d="M8 5v14l11-7z"/>
              </svg>
            </div>
          </a>
        ))}
      </div>
      <div class="mt-10 text-center">
        <a href="https://www.youtube.com/@AnaluMusic" target="_blank" rel="noopener"
          class="inline-block px-10 py-4 border border-white/30 text-white text-sm tracking-widest uppercase hover:border-[#c8a96e] hover:text-[#c8a96e] transition-all">
          VER MÁS EN YOUTUBE
        </a>
      </div>
    </div>
  </section>

  <!-- NEWSLETTER con fondo Analu9 -->
  <section id="newsletter" class="relative py-24 px-6 overflow-hidden">
    <img
      src="/Analu9.jpg"
      alt=""
      class="absolute inset-0 w-full h-full object-cover object-center opacity-20"
    />
    <div class="absolute inset-0 bg-[#0a0a0a]/80"></div>
    <div class="relative z-10 max-w-xl mx-auto text-center">
      <p class="text-[#c8a96e] tracking-[0.4em] text-xs uppercase mb-2">Mantente al día</p>
      <h2 class="text-6xl md:text-7xl text-white mb-4" style="font-family:'Bebas Neue',sans-serif">NEWSLETTER</h2>
      <p class="text-white/50 text-sm mb-10 tracking-wide">
        Recibe lo último de Analú directo en tu correo — nuevas canciones, fechas y más.
      </p>
      <form
        action="https://gmail.us7.list-manage.com/subscribe/post?u=1c0750f35bebca6e4043f0260&amp;id=cc0b1fa614&amp;f_id=00764ae4f0"
        method="post"
        target="_blank"
        class="flex flex-col gap-4"
      >
        <input
          type="email"
          name="EMAIL"
          placeholder="Tu correo electrónico"
          required
          class="w-full bg-transparent border border-white/20 px-5 py-4 text-white placeholder-white/30 text-sm tracking-wide focus:outline-none focus:border-[#c8a96e] transition-colors"
        />
        <!-- campo anti-spam requerido por Mailchimp, no eliminar -->
        <div aria-hidden="true" style="position:absolute;left:-5000px;">
          <input type="text" name="b_1c0750f35bebca6e4043f0260_cc0b1fa614" tabindex="-1" value="">
        </div>
        <button
          type="submit"
          class="w-full py-4 bg-[#c8a96e] text-black text-sm font-semibold tracking-widest uppercase hover:bg-white transition-colors"
        >
          SUSCRIBIRME
        </button>
      </form>
    </div>
  </section>

  <!-- CONTACT / REDES -->
  <section id="contacto" class="py-24 px-6 bg-[#0a0a0a]">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-[#c8a96e] tracking-[0.4em] text-xs uppercase mb-2">Sígueme</p>
      <h2 class="text-6xl md:text-8xl text-white mb-10" style="font-family:'Bebas Neue',sans-serif">REDES</h2>
      <div class="flex flex-wrap justify-center gap-4 mb-16">
        <!-- Instagram -->
        <a href="https://www.instagram.com/_analumusic/" target="_blank" rel="noopener"
          class="flex items-center gap-2 px-6 py-3 border border-white/20 text-white/70 text-sm tracking-widest uppercase hover:border-[#c8a96e] hover:text-[#c8a96e] transition-all">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
          </svg>
          Instagram
        </a>
        <!-- YouTube -->
        <a href="https://www.youtube.com/@AnaluMusic" target="_blank" rel="noopener"
          class="flex items-center gap-2 px-6 py-3 border border-white/20 text-white/70 text-sm tracking-widest uppercase hover:border-[#c8a96e] hover:text-[#c8a96e] transition-all">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M23.495 6.205a3.007 3.007 0 00-2.088-2.088c-1.87-.501-9.396-.501-9.396-.501s-7.507-.01-9.396.501A3.007 3.007 0 00.527 6.205a31.247 31.247 0 00-.522 5.805 31.247 31.247 0 00.522 5.783 3.007 3.007 0 002.088 2.088c1.868.502 9.396.502 9.396.502s7.506 0 9.396-.502a3.007 3.007 0 002.088-2.088 31.247 31.247 0 00.5-5.783 31.247 31.247 0 00-.5-5.805zM9.609 15.601V8.408l6.264 3.602z"/>
          </svg>
          YouTube
        </a>
        <!-- Facebook -->
        <a href="https://www.facebook.com/analumusic24" target="_blank" rel="noopener"
          class="flex items-center gap-2 px-6 py-3 border border-white/20 text-white/70 text-sm tracking-widest uppercase hover:border-[#c8a96e] hover:text-[#c8a96e] transition-all">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M24 12.073C24 5.405 18.627 0 12 0S0 5.405 0 12.073C0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047V9.41c0-3.025 1.792-4.697 4.533-4.697 1.312 0 2.686.236 2.686.236v2.97h-1.514c-1.491 0-1.956.93-1.956 1.886v2.268h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073z"/>
          </svg>
          Facebook
        </a>
        <!-- Spotify -->
        <a href="https://open.spotify.com/intl-es/artist/7wq81ecx1CuljMAKmQ0qbV" target="_blank" rel="noopener"
          class="flex items-center gap-2 px-6 py-3 border border-white/20 text-white/70 text-sm tracking-widest uppercase hover:border-[#c8a96e] hover:text-[#c8a96e] transition-all">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.441 17.314a.75.75 0 01-1.032.249c-2.823-1.724-6.376-2.114-10.565-1.158a.75.75 0 01-.334-1.463c4.583-1.047 8.516-.596 11.682 1.34a.75.75 0 01.249 1.032zm1.452-3.23a.937.937 0 01-1.288.308c-3.231-1.986-8.155-2.562-11.977-1.403a.937.937 0 01-.546-1.793c4.366-1.328 9.79-.685 13.503 1.6a.937.937 0 01.308 1.288zm.124-3.361c-3.876-2.302-10.276-2.514-13.974-1.39a1.125 1.125 0 01-.653-2.151c4.247-1.289 11.306-1.04 15.768 1.608a1.125 1.125 0 01-1.141 1.933z"/>
          </svg>
          Spotify
        </a>
        <!-- Apple Music -->
        <a href="https://music.apple.com/us/artist/anal%C3%BA/1458384047" target="_blank" rel="noopener"
          class="flex items-center gap-2 px-6 py-3 border border-white/20 text-white/70 text-sm tracking-widest uppercase hover:border-[#c8a96e] hover:text-[#c8a96e] transition-all">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
          </svg>
          Apple Music
        </a>
        <!-- TikTok -->
        <a href="https://www.tiktok.com/@analumusic8" target="_blank" rel="noopener"
